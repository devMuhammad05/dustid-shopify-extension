<!-- ── Banner ─────────────────────────────────────────────────── -->
<div class="dustid-banner page-width">
  <div class="dustid-banner__inner">
    <div class="dustid-banner__lead">
      <span class="dustid-banner__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 12 20 22 4 22 4 12"/>
          <rect x="2" y="7" width="20" height="5"/>
          <line x1="12" y1="22" x2="12" y2="7"/>
          <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/>
          <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/>
        </svg>
      </span>
      <div class="dustid-banner__text">
        <p class="dustid-banner__title">Powered by Dustid</p>
        <p class="dustid-banner__sub">Deliver to any contact — no address needed</p>
      </div>
    </div>
    <button class="button button--primary" id="d-signin">
      Connect Dustid
    </button>
  </div>
</div>

<!-- ── Phone modal · step 1 ───────────────────────────────────── -->
<div id="dustid-modal" class="dustid-overlay hidden" role="dialog" aria-modal="true" aria-label="Connect to Dustid">
  <div class="dustid-panel">
    <div class="dustid-panel__head">
      <div class="dustid-steps" aria-hidden="true">
        <span class="dustid-step dustid-step--on"></span>
        <span class="dustid-step-line"></span>
        <span class="dustid-step"></span>
        <span class="dustid-step-line"></span>
        <span class="dustid-step"></span>
      </div>
      <button class="dustid-close" id="dustid-cancel" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="dustid-panel__body">
      <p class="dustid-panel__eyebrow">Step 1 of 3</p>
      <h3 class="dustid-panel__title">Your phone number</h3>
      <p class="dustid-panel__hint">We'll send a one-time code to verify it's you</p>
      <input
        type="tel"
        id="dustid-phone"
        class="dustid-field"
        placeholder="+1 (555) 000-0000"
        autocomplete="tel"
      />
      <button class="button button--primary dustid-btn-full" id="dustid-connect">
        Continue
      </button>
    </div>
  </div>
</div>

<!-- ── OTP modal · step 2 ─────────────────────────────────────── -->
<div id="dustid-otp-modal" class="dustid-overlay hidden" role="dialog" aria-modal="true" aria-label="Enter verification code">
  <div class="dustid-panel">
    <div class="dustid-panel__head">
      <div class="dustid-steps" aria-hidden="true">
        <span class="dustid-step dustid-step--done"></span>
        <span class="dustid-step-line dustid-step-line--done"></span>
        <span class="dustid-step dustid-step--on"></span>
        <span class="dustid-step-line"></span>
        <span class="dustid-step"></span>
      </div>
      <button class="dustid-close" id="dustid-otp-back" aria-label="Go back">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
    </div>
    <div class="dustid-panel__body">
      <p class="dustid-panel__eyebrow">Step 2 of 3</p>
      <h3 class="dustid-panel__title">Enter the code</h3>
      <p class="dustid-panel__hint">Sent to <strong id="dustid-otp-phone"></strong></p>
      <div class="dustid-otp-fields">
        <input type="text" class="dustid-otp-cell" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="one-time-code" />
        <input type="text" class="dustid-otp-cell" maxlength="1" inputmode="numeric" pattern="[0-9]" />
        <input type="text" class="dustid-otp-cell" maxlength="1" inputmode="numeric" pattern="[0-9]" />
        <input type="text" class="dustid-otp-cell" maxlength="1" inputmode="numeric" pattern="[0-9]" />
        <input type="text" class="dustid-otp-cell" maxlength="1" inputmode="numeric" pattern="[0-9]" />
        <input type="text" class="dustid-otp-cell" maxlength="1" inputmode="numeric" pattern="[0-9]" />
      </div>
      <button class="button button--primary dustid-btn-full" id="dustid-verify">
        Verify
      </button>
      <button class="dustid-back" type="button" id="dustid-resend">Resend code</button>
    </div>
  </div>
</div>

<!-- ── Contacts modal · step 3 ───────────────────────────────── -->
<div id="dustid-contacts-modal" class="dustid-overlay hidden" role="dialog" aria-modal="true" aria-label="Select a contact">
  <div class="dustid-panel dustid-panel--tall">
    <div class="dustid-panel__head">
      <div class="dustid-steps" aria-hidden="true">
        <span class="dustid-step dustid-step--done"></span>
        <span class="dustid-step-line dustid-step-line--done"></span>
        <span class="dustid-step dustid-step--done"></span>
        <span class="dustid-step-line dustid-step-line--done"></span>
        <span class="dustid-step dustid-step--on"></span>
      </div>
      <button class="dustid-close" id="dustid-contacts-back" aria-label="Go back">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>
    </div>
    <div class="dustid-panel__body">
      <p class="dustid-panel__eyebrow">Step 3 of 3</p>
      <h3 class="dustid-panel__title">Who are you sending to?</h3>
      <p class="dustid-panel__hint">Contacts who have shared their address with you</p>
      <input
        type="text"
        id="dustid-contact-search"
        class="dustid-field"
        placeholder="Search contacts…"
        autocomplete="off"
      />
      <ul id="dustid-contact-list" class="dustid-contact-list" role="listbox" aria-label="Contacts"></ul>
      <p id="dustid-contacts-empty" class="dustid-contacts-empty hidden">No contacts found</p>
    </div>
  </div>
</div>

{{ 'widget.css' | asset_url | stylesheet_tag }}
<script src="{{ 'widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Dustid Gift Widget",
  "target": "section",
  "settings": []
}
{% endschema %}
