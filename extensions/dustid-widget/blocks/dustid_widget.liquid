<div class="dustid-banner page-width">
  <div class="dustid-icon">🎁</div>

  <div class="dustid-content">
    <p class="dustid-title">Dustid</p>
    <p class="dustid-subtext">
      Deliver to any contact — no address needed
    </p>
  </div>

  <div class="dustid-actions">
    <button class="button button--primary" id="d-signin">
      Connect Dustid →
    </button>
  </div>
</div>


<div id="dustid-modal" class="dustid-modal hidden">
  <div class="dustid-modal-content">
    <h3>Connect to Dustid</h3>

    <input
      type="tel"
      id="dustid-phone"
      placeholder="Enter phone number"
      class="dustid-input"
    />

    <button class="button button--primary" id="dustid-connect">
      Continue
    </button>

    <button class="dustid-cancel" id="dustid-cancel">
      Cancel
    </button>
  </div>
</div>

<div id="dustid-otp-modal" class="dustid-modal hidden">
  <div class="dustid-modal-content">
    <h3>Enter OTP</h3>
    <p class="dustid-otp-hint">We sent a code to <span id="dustid-otp-phone"></span></p>

    <div class="dustid-otp-fields">
      <input type="text" class="dustid-otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
      <input type="text" class="dustid-otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
      <input type="text" class="dustid-otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
      <input type="text" class="dustid-otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
      <input type="text" class="dustid-otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
      <input type="text" class="dustid-otp-input" maxlength="1" inputmode="numeric" pattern="[0-9]" />
    </div>

    <button class="button button--primary" id="dustid-verify">
      Verify
    </button>

    <button class="dustid-cancel" id="dustid-otp-back">
      Back
    </button>
  </div>
</div>

<div id="dustid-contacts-modal" class="dustid-modal hidden">
  <div class="dustid-modal-content dustid-contacts-content">
    <h3>Who are you sending to?</h3>
    <p class="dustid-otp-hint">Select a contact who has shared their address with you</p>

    <input
      type="text"
      id="dustid-contact-search"
      class="dustid-input"
      placeholder="Search contacts..."
    />

    <ul id="dustid-contact-list" class="dustid-contact-list">
      <!-- populated by JS -->
    </ul>

    <p id="dustid-contacts-empty" class="dustid-contacts-empty hidden">
      No contacts found
    </p>

    <button class="dustid-cancel" id="dustid-contacts-back">
      Back
    </button>
  </div>
</div>

{{ 'widget.css' | asset_url | stylesheet_tag }}
<script src="{{ 'widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Dustid Gift Widget",
  "target": "section",
  "settings": []
}
{% endschema %}
